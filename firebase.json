{
  "hosting": {
    "public": "static",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      }
    ]
  },
  "functions": {
    "source": ".",
    "codebase": "default",
    "ignore": [
      "static/**",
      ".venv/**",
      "venv/**",
      ".git/**",
      "__pycache__/**",
      "data/*.db"
    ]
  }
}
