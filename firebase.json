{
  "hosting": {
    "public": "static",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ],
    "rewrites": []
  },
  "functions": {
    "source": ".",
    "codebase": "default",
    "ignore": [
      "static/**",
      ".venv/**",
      "venv/**",
      ".git/**",
      "__pycache__/**",
      "data/*.db"
    ]
  }
}
